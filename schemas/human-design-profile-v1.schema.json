{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://human-design.wonderelian.com/schemas/human-design-profile-v1.schema.json",
  "title": "HumanDesignProfileSnapshot",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "engineVersion", "verificationStatus", "chartHash", "generatedAt", "input", "core", "activations", "structure", "meta"],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "engineVersion": { "const": "1.0.0" },
    "verificationStatus": { "enum": ["client_asserted", "engine_verified"] },
    "chartHash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "generatedAt": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]{3})?Z$" },
    "input": { "$ref": "#/$defs/input" },
    "core": { "$ref": "#/$defs/core" },
    "activations": {
      "type": "object",
      "additionalProperties": false,
      "required": ["personality", "design"],
      "properties": {
        "personality": { "$ref": "#/$defs/activationSet" },
        "design": { "$ref": "#/$defs/activationSet" }
      }
    },
    "structure": { "$ref": "#/$defs/structure" },
    "meta": { "$ref": "#/$defs/meta" }
  },
  "$defs": {
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["birthDate", "birthTime", "timezone", "locationLabel"],
      "properties": {
        "birthDate": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
        "birthTime": { "type": "string", "pattern": "^(?:[01][0-9]|2[0-3]):[0-5][0-9]$" },
        "timezone": { "type": "string", "minLength": 1, "maxLength": 64 },
        "locationLabel": { "type": "string", "maxLength": 160 }
      }
    },
    "core": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "strategy", "authority", "profile", "definition", "incarnationCross"],
      "properties": {
        "type": { "enum": ["Generator", "Manifesting Generator", "Manifestor", "Projector", "Reflector"] },
        "strategy": { "enum": ["To Respond", "To Inform", "Wait for the Invitation", "Wait a Lunar Cycle"] },
        "authority": { "enum": ["Emotional - Solar Plexus", "Sacral", "Splenic", "Ego Manifested", "Ego Projected", "Self-Projected", "Lunar", "Mental - Environment"] },
        "profile": { "enum": ["1/3", "1/4", "2/4", "2/5", "3/5", "3/6", "4/6", "4/1", "5/1", "5/2", "6/2", "6/3"] },
        "definition": { "enum": ["No Definition", "Single Definition", "Split Definition", "Triple Split Definition", "Quadruple Split Definition"] },
        "incarnationCross": { "type": "string", "minLength": 1, "maxLength": 200 }
      }
    },
    "activationSet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sun", "earth", "northNode", "southNode", "moon", "mercury", "venus", "mars", "jupiter", "saturn", "uranus", "neptune", "pluto"],
      "properties": {
        "sun": { "$ref": "#/$defs/activation" },
        "earth": { "$ref": "#/$defs/activation" },
        "northNode": { "$ref": "#/$defs/activation" },
        "southNode": { "$ref": "#/$defs/activation" },
        "moon": { "$ref": "#/$defs/activation" },
        "mercury": { "$ref": "#/$defs/activation" },
        "venus": { "$ref": "#/$defs/activation" },
        "mars": { "$ref": "#/$defs/activation" },
        "jupiter": { "$ref": "#/$defs/activation" },
        "saturn": { "$ref": "#/$defs/activation" },
        "uranus": { "$ref": "#/$defs/activation" },
        "neptune": { "$ref": "#/$defs/activation" },
        "pluto": { "$ref": "#/$defs/activation" }
      }
    },
    "activation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gate", "line", "color", "tone", "base", "longitude"],
      "properties": {
        "gate": { "type": "integer", "minimum": 1, "maximum": 64 },
        "line": { "type": "integer", "minimum": 1, "maximum": 6 },
        "color": { "type": "integer", "minimum": 1, "maximum": 6 },
        "tone": { "type": "integer", "minimum": 1, "maximum": 6 },
        "base": { "type": "integer", "minimum": 1, "maximum": 5 },
        "longitude": { "type": "number", "minimum": 0, "exclusiveMaximum": 360 }
      }
    },
    "structure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["definedCenters", "channels", "variables"],
      "properties": {
        "definedCenters": {
          "type": "array",
          "uniqueItems": true,
          "items": { "enum": ["head", "ajna", "throat", "g", "heart", "sacral", "spleen", "solar plexus", "root"] }
        },
        "channels": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/channel" }
        },
        "variables": {
          "type": "object",
          "additionalProperties": false,
          "required": ["digestion", "environment", "awareness", "perspective"],
          "properties": {
            "digestion": { "enum": ["<", ">"] },
            "environment": { "enum": ["<", ">"] },
            "awareness": { "enum": ["<", ">"] },
            "perspective": { "enum": ["<", ">"] }
          }
        }
      }
    },
    "channel": {
      "oneOf": [
        { "const": [1, 8] }, { "const": [2, 14] }, { "const": [3, 60] }, { "const": [4, 63] },
        { "const": [5, 15] }, { "const": [6, 59] }, { "const": [7, 31] }, { "const": [9, 52] },
        { "const": [10, 20] }, { "const": [10, 34] }, { "const": [10, 57] }, { "const": [11, 56] },
        { "const": [12, 22] }, { "const": [13, 33] }, { "const": [16, 48] }, { "const": [17, 62] },
        { "const": [18, 58] }, { "const": [19, 49] }, { "const": [20, 34] }, { "const": [20, 57] },
        { "const": [21, 45] }, { "const": [23, 43] }, { "const": [24, 61] }, { "const": [25, 51] },
        { "const": [26, 44] }, { "const": [27, 50] }, { "const": [28, 38] }, { "const": [29, 46] },
        { "const": [30, 41] }, { "const": [32, 54] }, { "const": [34, 57] }, { "const": [35, 36] },
        { "const": [37, 40] }, { "const": [39, 55] }, { "const": [42, 53] }, { "const": [47, 64] }
      ]
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ephemeris", "nodeType", "designSolarArc", "birthUtc", "designJulianDay"],
      "properties": {
        "ephemeris": { "const": "Swiss Ephemeris" },
        "nodeType": { "const": "True Node" },
        "designSolarArc": { "const": 88 },
        "birthUtc": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T" },
        "designJulianDay": { "type": "number" }
      }
    }
  }
}
